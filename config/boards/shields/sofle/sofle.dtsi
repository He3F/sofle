/*
 * Copyright (c) 2024 He3F
 * SPDX-License-Identifier: MIT
 *
 * Sofle split keyboard – shared base (left + right)
 *
 * Matrix layout (both halves combined, 5 rows × 14 cols):
 *
 *  Rows 0-2  – 12 keys per row; cols 6 and 7 are skipped (encoder-button
 *               positions on each half, not wired into the alpha/number rows)
 *  Rows 3-4  – 14 keys per row; all 7 cols per half are present, including
 *               the encoder-button column (col 6 left / col 7 right)
 *
 *  Left  half → physical cols 0-6   → transform cols 0-6
 *  Right half → physical cols 0-6   → transform cols 7-13 (col-offset = <7>)
 *
 * All GPIO pin lists live in the per-side overlays; this file only defines
 * the transform shape and the kscan skeleton.
 */

#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan            = &kscan0;
        zmk,matrix-transform = &default_transform;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns    = <14>;
        rows       = <5>;

        /*
         * Reading order = left-to-right across the split gap, top-to-bottom.
         * Cols 6 & 7 (encoder buttons) are absent from rows 0-2.
         *
         *   L:  RC(r,0)…RC(r,5)           R:  RC(r,8)…RC(r,13)   ← rows 0-2
         *   L:  RC(r,0)…RC(r,6)  RC(r,7)…RC(r,13)                ← rows 3-4
         */
        map = <
            RC(0,0)  RC(0,1)  RC(0,2)  RC(0,3)  RC(0,4)  RC(0,5)                                   RC(0,8)  RC(0,9)  RC(0,10) RC(0,11) RC(0,12) RC(0,13)
            RC(1,0)  RC(1,1)  RC(1,2)  RC(1,3)  RC(1,4)  RC(1,5)                                   RC(1,8)  RC(1,9)  RC(1,10) RC(1,11) RC(1,12) RC(1,13)
            RC(2,0)  RC(2,1)  RC(2,2)  RC(2,3)  RC(2,4)  RC(2,5)                                   RC(2,8)  RC(2,9)  RC(2,10) RC(2,11) RC(2,12) RC(2,13)
            RC(3,0)  RC(3,1)  RC(3,2)  RC(3,3)  RC(3,4)  RC(3,5)  RC(3,6)  RC(3,7)  RC(3,8)  RC(3,9)  RC(3,10) RC(3,11) RC(3,12) RC(3,13)
            RC(4,0)  RC(4,1)  RC(4,2)  RC(4,3)  RC(4,4)  RC(4,5)  RC(4,6)  RC(4,7)  RC(4,8)  RC(4,9)  RC(4,10) RC(4,11) RC(4,12) RC(4,13)
        >;
    };

    /*
     * kscan skeleton – GPIO lists are supplied entirely by the per-side
     * overlays (sofle_left.overlay / sofle_right.overlay), so this node
     * intentionally contains only the three properties that must be fixed
     * at build time regardless of which half is compiled.
     */
    kscan0: kscan {
        compatible      = "zmk,kscan-gpio-matrix";
        label           = "KSCAN";
        diode-direction = "col2row";
    };
};
